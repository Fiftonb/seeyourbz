// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  submissions UserSubmission[]

  @@map("users")
}

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        DateTime
  solarDate   String   // 公历日期字符串
  lunarDate   String   // 农历日期字符串
  userId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([title, userId])
  @@map("calendar_events")
}

model UserSubmission {
  id            String   @id @default(cuid())
  type          String   // 'constellation' 或 'peach-blossom'
  ipAddress     String   // 用户IP地址
  userAgent     String?  // 用户浏览器信息
  inputData     String   // JSON格式的输入数据
  resultData    String?  // JSON格式的计算结果（可选）
  userId        String?  // 关联用户ID（如果已登录）
  createdAt     DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("user_submissions")
} 