{
  "name": "seeyourbz",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 12333",
    "build": "next build",
    "start": "next start -p 12333",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:backup": "mkdir -p prisma/backups && cp prisma/dev.db prisma/backups/dev-$(date +%Y%m%d-%H%M%S).db && echo 'Database backed up to prisma/backups/'",
    "db:backup:dump": "mkdir -p prisma/backups && sqlite3 prisma/dev.db .dump > prisma/backups/dump-$(date +%Y%m%d-%H%M%S).sql",
    "db:restore": "echo 'Please specify backup file: npm run db:restore:file -- <backup-file>'",
    "db:restore:file": "cp",
    "db:reset": "rm -f prisma/dev.db && npm run db:push && npm run db:seed",
    "db:backup:clean": "find prisma/backups -name '*.db' -mtime +30 -delete 2>/dev/null || true && find prisma/backups -name '*.sql' -mtime +30 -delete 2>/dev/null || true",
    "db:backup:linux": "./scripts/backup-db-linux.sh",
    "db:backup:macos": "./scripts/backup-db.sh"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@prisma/client": "^5.7.0",
    "@types/qrcode": "^1.5.5",
    "autoprefixer": "^10.4.16",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "framer-motion": "^12.23.0",
    "html-to-image": "^1.11.13",
    "jose": "^5.2.0",
    "lucide-react": "^0.321.0",
    "next": "^14.2.30",
    "postcss": "^8.4.32",
    "prisma": "^5.7.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "tyme4ts": "^1.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.10.6",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
