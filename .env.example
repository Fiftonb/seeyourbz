# ============================================================
# seeyourbz 环境变量配置示例
# 复制此文件为 .env.local 并填入真实值
# 生成随机密钥: openssl rand -base64 32
# ============================================================


# ============================================================
# 数据库
# ============================================================

# SQLite 数据库路径（开发环境）
DATABASE_URL="file:./dev.db"


# ============================================================
# 站点配置
# ============================================================

# 网站完整 URL（用于 sitemap、SEO 等）
NEXT_PUBLIC_SITE_URL="https://your-domain.com"

# NextAuth 配置
NEXTAUTH_URL="http://localhost:12333"
# 可使用 openssl rand -base64 32 生成
NEXTAUTH_SECRET="your-nextauth-secret-change-this"


# ============================================================
# JWT 认证
# ============================================================

# JWT 签名密钥，用于 session 加密
# 可使用 openssl rand -base64 32 生成
JWT_SECRET="your-jwt-secret-change-this"


# ============================================================
# 人生K线图 - 内置 AI API 配置
# （用于为用户提供"内置API"模式，隐藏真实 key）
# ============================================================

# 兼容 OpenAI 格式的 API Base URL
# 示例: https://api.openai.com/v1
#       https://generativelanguage.googleapis.com/v1beta/openai
BUILTIN_API_BASE_URL="https://api.openai.com/v1"

# 使用的模型名称
# 示例: gpt-4o-mini, gemini-2.5-flash, claude-3-5-haiku-20241022
BUILTIN_MODEL_NAME="gpt-4o-mini"

# 内置 API 的真实 Key（永远不要提交到 git）
BUILTIN_API_KEY="sk-your-api-key-here"

# 用户访问内置 API 时需要输入的口令（防止滥用）
# 可使用 openssl rand -base64 12 生成一个短密钥
BUILTIN_ACCESS_PASSWORD="your-access-password"


# ============================================================
# 百度搜索 SEO 推送（可选）
# ============================================================

# 你的网站域名（百度站长平台注册的域名）
BAIDU_SITE="your-domain.com"

# 百度站长平台的推送 Token
# 获取地址: https://ziyuan.baidu.com/linksubmit/index
BAIDU_TOKEN="your-baidu-push-token"